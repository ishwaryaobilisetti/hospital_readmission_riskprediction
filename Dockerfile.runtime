FROM python:3.12-slim

WORKDIR /app

COPY requirements.runtime.txt .
ENV PIP_DEFAULT_TIMEOUT=300
ENV PIP_REQUIRE_HASHES=0
RUN pip install --no-cache-dir --retries 10 --default-timeout 300 --prefer-binary -r requirements.runtime.txt

# Copy repository files
COPY . .

# Default: run quick verification of the serialized pipeline
CMD ["python", "src/verify_pipeline.py"]
